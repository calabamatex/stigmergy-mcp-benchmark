{
  "name": "@stigmergy-benchmark/dashboard",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc && cd frontend && npx vite build --outDir ../dist/public",
    "start": "node dist/server.js",
    "dev": "node dist/server.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@stigmergy-benchmark/core": "workspace:*",
    "@stigmergy-benchmark/engine": "workspace:*",
    "@stigmergy-benchmark/storage": "workspace:*",
    "@stigmergy-benchmark/tasks": "workspace:*",
    "@stigmergy-benchmark/llm-client": "workspace:*",
    "express": "^4.21.0",
    "ws": "^8.18.0",
    "cors": "^2.8.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/ws": "^8.5.13",
    "@types/cors": "^2.8.17"
  }
}
