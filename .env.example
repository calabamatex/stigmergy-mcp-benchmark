# LLM Provider API Keys (required for non-mock providers)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...
OLLAMA_BASE_URL=http://localhost:11434

# Database path (optional, defaults to ./stigmergy-benchmark.db)
STIGMERGY_BENCHMARK_DB=./stigmergy-benchmark.db

# Dashboard port (optional, defaults to 3456)
PORT=3456
